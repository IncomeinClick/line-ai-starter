# LINE Messaging API credentials.
# From the LINE Developers console: your Provider > Channel > "Messaging API" tab.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Optional: which Claude model the chat brain uses (default: sonnet)
BRAIN_MODEL=sonnet

# Optional: active-list settings
# ACTIVE_LIST_START=2026-01-01   # build the audience from this date onward
# TZ_OFFSET=7                    # your timezone offset from UTC, in hours
